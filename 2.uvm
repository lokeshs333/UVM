`include "uvm_macros.svh"   // UVM macros
import uvm_pkg::*;          // Import UVM package

module tb;

  int data = 56;            // Integer variable

  initial begin
    // Print formatted message using UVM
    `uvm_info("TB_TOP", $sformatf("Value of data : %0d", data), UVM_NONE);
  end

endmodule
